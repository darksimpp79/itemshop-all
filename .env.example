# ═══════════════════════════════════════════════════════════════
#  ItemShop — zmienne środowiskowe produkcyjne
#  Skopiuj do .env, uzupełnij, chmod 600 .env
#  NIGDY nie commituj .env do git!
# ═══════════════════════════════════════════════════════════════

# ── Baza danych ────────────────────────────────────────────────
DB_USER=itemshop
DB_PASSWORD=ZMIEN_NA_SILNE_HASLO

# ── JWT ────────────────────────────────────────────────────────
# Wygeneruj: openssl rand -base64 48
JWT_SECRET=ZMIEN_NA_LOSOWY_STRING_MIN_32_ZNAKI

# ── Stripe ─────────────────────────────────────────────────────
# Live keys z dashboard.stripe.com
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Utwórz produkty w Stripe Dashboard → skopiuj Price ID (price_...)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_STARTER_MONTHLY=price_...

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── URL aplikacji ──────────────────────────────────────────────
APP_BASE_URL=https://api.pumpking.club
FRONTEND_BASE_URL=https://pumpking.club
CORS_ALLOWED_ORIGINS=https://pumpking.club,https://*.pumpking.club

# ── Cloudflare API (custom domeny Pro userów) ──────────────────
CLOUDFLARE_CLIENT_ID=YOUR_CLOUDFLARE_CLIENT_ID
CLOUDFLARE_CLIENT_SECRET=YOUR_CLOUDFLARE_CLIENT_SECRET
CLOUDFLARE_REDIRECT_URI=https://api.pumpking.club/api/admin/cloudflare/callback
